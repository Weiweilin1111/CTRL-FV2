        <mxCell id="sb1" value="📈 系統監控（2.5s 更新）&#10;串流／推論 FPS・延遲&#10;VRAM 進度條・儲存用量&#10;版本一致性警告" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bbbbbb;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
